{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["@types/bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "@summit/jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "*": ["./*"],
      "@/*": ["./*"],
      "@shared": ["./src/shared.ts"],
      "@summit/jsx/jsx-runtime": ["./src/sections/presentation/jsx/jsx-runtime.ts"],
      "@summit/jsx/jsx-dev-runtime": ["./src/sections/presentation/jsx/jsx-runtime.ts"],
      "@rhythm/*": ["./src/sections/rhythm/*"]
    }
  },
  "include": ["sandstone.config.ts", "src", "scripts"]
}
