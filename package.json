{
  "name": "sandstone-template",
  "version": "0.0.1",
  "description": "A pack created with Sandstone",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev:watch": "sand watch",
    "dev:build": "sand build && bun run scripts/minify-resourcepack.ts",
    "dev:build:force": "FORCE_RENDER=1 bun dev:build",
    "dev:diff:check": "bun run scripts/diff-build.ts",
    "dev:diff:snapshot": "bun run scripts/diff-build.ts snapshot",
    "dev:history:generate": "bun run scripts/generate-build-history.ts",
    "dev:deploy": "bun run scripts/deploy.ts",
    "fetch:parsers": "bun run scripts/fetch-syntax-parsers.ts",
    "typecheck": "tsc --noEmit 2>&1 | awk '/^src\\/sections\\/(magic|rhythm|elevator)/{s=1;next} s&&/^[[:space:]]/{next} /^[^[:space:]]/{s=0} {print}'"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "@types/less": "^3.0.8",
    "adm-zip": "^0.5.17",
    "sandstone-cli": "^2.4.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nbsjs/core": "^6.1.0",
    "@tonejs/midi": "^2.0.28",
    "less": "^4.6.7",
    "postcss-selector-parser": "^7.1.4",
    "sandstone": "^1.1.1",
    "sharp": "^0.35.3",
    "socket.io-client": "^4.8.3",
    "web-tree-sitter": "^0.26.7"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
